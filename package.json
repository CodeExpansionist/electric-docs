{
  "name": "electric",
  "description": "Pixel-perfect clone of Electriz TV & Audio section",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:layout": "node scripts/lint-layout.js",
    "facts": "node scripts/generate-repo-facts.js",
    "audit": "node scripts/audit-docs.js",
    "preflight": "npm run facts && npm run audit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:component": "vitest run --project component",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --project=chromium",
    "test:parity": "playwright test --project=parity --grep @parity",
    "test:parity:regression": "playwright test --project=parity --grep @regression-visual",
    "test:parity:update": "playwright test --project=parity --grep @regression-visual --update-snapshots",
    "test:parity:report": "playwright test --project=parity --grep @parity && cat artifacts/parity/reports/parity-report.md",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @smoke|@regression",
    "test:all": "npm run test && npm run test:e2e",
    "test:ci": "npm run test:coverage && npm run test:e2e"
  },
  "dependencies": {
    "next": "^15.5.12",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.37",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8",
    "eslint-config-next": "^15.5.12",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
