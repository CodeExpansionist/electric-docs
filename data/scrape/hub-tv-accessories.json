  "helpCards": [
    {
      "title": "TV screen size",
      "description": "TV screen size is measured diagonally from the bottom left corner to the top right. Use the same method to measure how much space you have, then shop by screen size.",
      "imageUrl": "https://media.electriz.biz/i/electrizprod/televisions-screen-size-new?fmt=auto&$q-large$",
      "url": "/techtalk/tv-advice/tv-technology/what-size-tv-should-i-buy.html"
    },
    {
      "title": "What is a smart TV?",
      "description": "A smart TV has catch-up and on-demand streaming services built-in, so you don't need any extra sticks or boxes. Some also let you use social media, Spotify and games.",
      "imageUrl": "https://media.electriz.biz/i/electrizprod/televisions-smart-tv?fmt=auto&$q-large$",
      "url": "/tv-and-audio/televisions/tvs/smart-tvs"
    },
    {
      "title": "Audio set-up",
      "description": "Want a better listening experience than your in-built TV speaker? Look out for sound bars and other audio systems with surround sound, clear voice tech and object tracking.",
      "imageUrl": "https://media.electriz.biz/i/electrizprod/televisions-audio-set-up?fmt=auto&$q-large$",
      "url": "/tv-and-audio/dvd-blu-ray-and-home-cinema/home-cinema-systems-and-soundbars/sound-bars"
    },
    {
      "title": "What is 4K Ultra HD?",
      "description": "4K Ultra HD is the name of the screen resolution four times clearer than a Full HD TV. It delivers a cinema quality picture, with crisp images and accurate colours.",
      "imageUrl": "https://media.electriz.biz/i/electrizprod/televisions-4k-ultra-hd-new?fmt=auto&$q-large$",
      "url": "/tv-and-audio/televisions/tvs/4k-ultra-hd-tvs"
    }
  ],
