    },
    {
      "title": "Subwoofers",
      "description": "Add extra bass and give your sound some oomph. Connecting a subwoofer to your soundbar will really ramp up your favourite playlists, and make those big movie moments even bigger.",
      "imageUrl": "https://media.electriz.biz/i/electrizprod/Home-cinema-DVD-Blu-ray-high-subwoofer-new?fmt=auto&$q-large$",
      "url": "/tv-and-audio/dvd-blu-ray-and-home-cinema/home-cinema-systems-and-soundbars/soundbar-subwoofers"
    },
    {
      "title": "High-resolution audio",
      "description": "Hi-res audio has superior quality and sounds as close to the original recording as possible. If you're after seriously good sound, hi-res audio is the way to go.",
      "imageUrl": "https://media.electriz.biz/i/electrizprod/Home-cinema-DVD-Blu-ray-high-resolution-audio?fmt=auto&$q-large$",
      "url": "/tv-and-audio/dvd-blu-ray-and-home-cinema/home-cinema-systems-and-soundbars/sound-bars"
    },
    {
      "title": "Voice-activated sound systems",
      "description": "Play your favourite songs without pressing a single button. Speakers with built-in voice assistants, like Alexa or Google, let you fill your home with music using simple voice commands.",
