  "seoContent": {
    "heading": "",
    "columns": [
      {
        "heading": "Picking the right home cinema setup",
        "text": "Soundbars are the perfect foundation for your home cinema system. Most come with subwoofers for deeper bass, but if you want seriously cinematic sound, you can add wireless speakers too. All-in-One Soundbars have a subwoofer already built-in, so you won't need to worry about buying anything additional."
      },
      {
        "heading": "Multi-room and smart sound",
        "text": "Play the same song on multiple speakers, or control a dozen different speakers around your home with multi-room and smart sound speakers. You can connect to your sound bar, subwoofer, TV, and rear speakers to create a true surround sound experience."
      },
      {
        "heading": "DVD and Blu-ray players",
        "text": "Finish your home cinema setup with a DVD or Blu-ray player to watch your favourite films. If you want to really bring the big screen home, a 4K Blu-ray player is the perfect choice for great quality movie nights."
      }
    ]
  }
